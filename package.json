{
  "name": "sailapplication",
  "version": "1.0.0",
  "description": "Location history explorer - discover significance, traditions, legacy, stories, beliefs, and myths of any place",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node server/index.js",
    "dev:frontend": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "fuse.js": "^7.0.0",
    "wikipedia": "^2.1.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
